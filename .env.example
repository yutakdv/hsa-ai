APP_NAME=hsa-ai
APP_ENV=local
LOG_LEVEL=INFO

# 서버 바인딩 (Docker: 0.0.0.0 / 로컬 직접 실행: 127.0.0.1)
HOST=0.0.0.0
PORT=8000

OPENAI_API_KEY=

# LLM 모델 (명시 > 이 환경변수 > llm_client.py 기본값 순서로 결정됨)
HSA_LLM_MODEL=openai:gpt-5-nano

# RAG 유사도 임계값 (0.0~1.0, 기본 0.4)
RAG_RELEVANCE_THRESHOLD=0.4

# RAG 벡터 검색 후보 수 (기본 6)
RAG_TOP_K=6

# LLM reranker가 최종 선택할 문서 수 (기본 3)
RAG_RERANK_TOP_N=3

# LlamaIndex LLM reranker 전용 OpenAI 모델
RAG_RERANK_MODEL=gpt-5-nano

# 인덱스 디스크 저장 경로 (기본 ./storage)
RAG_STORAGE_DIR=./storage
